<h1 class="text-3xl font-bold mb-4 flex items-center justify-center">成果物一覧</h1>
<% @categories.each do |category| %>
    <div class="bg-white rounded-lg shadow-md p-6 max-w-2xl mx-auto mb-6">
        <div class="text-lg font-semibold mb-4 flex items-center justify-center">
            <%= category[:name] %>
        </div>
        <ul>
            <% category[:projects].each do |project| %>
                <li class="border-b last:border-b-0 py-4">
                    <div class="flex justify-between items-center gap-2">
                        <span class="text-base font-bold text-gray-900"><%= project[:name] %></span>
                        <div class="space-x-2 shrink-0">
                            <% if project[:site].present? %>
                                <a class="text-blue-500 hover:underline" href="<%= project[:site] %>" target="_blank">サイトへ</a>
                            <% end %>
                            <% if project[:github].present? %>
                                <a class="text-blue-500 hover:underline" href="<%= project[:github] %>" target="_blank">GitHub</a>
                            <% end %>
                        </div>
                    </div>
                    <% if project[:description].present? %>
                        <p class="text-sm font-normal text-gray-500 leading-relaxed mt-1.5 pl-4 border-l-2 border-gray-200 whitespace-pre-line"><%= project[:description] %></p>
                    <% end %>
                </li>
            <% end %>
        </ul>
    </div>
<% end %>
